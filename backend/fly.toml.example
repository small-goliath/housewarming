# Fly.io 배포 설정 예시. `fly launch` 후 생성되는 파일을 이 형태로 조정한다.
# 사용 시 `backend/fly.toml` 로 복사하고 app 이름을 본인 것으로 수정.
# 배포: 저장소 루트에서  fly deploy --config backend/fly.toml --dockerfile backend/Dockerfile

app = "dotori-housewarming-api"
primary_region = "nrt"   # Tokyo (서울 근접)

[build]
  dockerfile = "Dockerfile"

[http_service]
  internal_port = 8000
  force_https = true
  auto_stop_machines = "stop"
  auto_start_machines = true
  min_machines_running = 0

[[vm]]
  size = "shared-cpu-1x"
  memory = "256mb"

# 시크릿은 파일에 두지 말고 CLI 로 설정:
#   fly secrets set SUPABASE_URL=... SUPABASE_ANON_KEY=... \
#     SUPABASE_SERVICE_ROLE_KEY=... ADMIN_KAKAO_IDS=... \
#     ALLOWED_ORIGINS=https://<vercel-도메인>
